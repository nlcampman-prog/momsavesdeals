---
import BaseLayout from '../../layouts/BaseLayout.astro';
const articles = Object.values(import.meta.glob('../../content/articles/*.mdx', { eager: true }));
const cats = new Map<string, number>();
articles.forEach((a: any) => { const c = a.frontmatter?.category; if (c) cats.set(c, (cats.get(c) || 0) + 1); });
const categories = Array.from(cats.entries()).sort((a, b) => b[1] - a[1]);
---
<BaseLayout title="Categories" description="Browse parenting deals by category. Find discount codes for baby gear, toys, essentials, and more.">
  <div class="container"><div class="category-header"><h1>Browse by Category</h1><p>Find the best deals for your family.</p></div>
    <div class="card-grid">{categories.map(([name, count]) => { const slug = name.toLowerCase().replace(/\s+/g, '-'); return (<a href={`/categories/${slug}/`} class="card" style="text-decoration:none;color:inherit;"><span class="card-category">{name}</span><h2 class="card-title" style="margin-top:0.5rem;">{name}</h2><p class="card-meta">{count} deal{count !== 1 ? 's' : ''}</p></a>); })}</div>
  </div>
</BaseLayout>